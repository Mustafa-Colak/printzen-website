---
import { getAlternatePath, type Locale } from '../utils/i18n';

interface Props {
  title: string;
  description?: string;
  lang: Locale;
  /** Override the auto-computed alternate-locale URL — needed when the two locales use different slugs (e.g. translated guide URLs). */
  alternatePath?: string;
}
const { title, description, lang, alternatePath: alternatePathProp } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const alternatePath = alternatePathProp ?? getAlternatePath(Astro.url.pathname, lang);
const alternateURL = new URL(alternatePath, Astro.site);
const enURL = lang === 'en' ? canonicalURL : alternateURL;
const trURL = lang === 'tr' ? canonicalURL : alternateURL;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Printzen',
  url: 'https://printzen.app',
  logo: 'https://printzen.app/favicon.svg',
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description}>}
  <link rel="canonical" href={canonicalURL}>
  <link rel="alternate" hreflang="en" href={enURL}>
  <link rel="alternate" hreflang="tr" href={trURL}>
  <link rel="alternate" hreflang="x-default" href={enURL}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" href="/favicon.ico">

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Printzen">
  <meta property="og:title" content={title}>
  {description && <meta property="og:description" content={description}>}
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:locale" content={lang === 'tr' ? 'tr_TR' : 'en_US'}>
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  {description && <meta name="twitter:description" content={description}>}

  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

  <script is:inline src="https://cdn.tailwindcss.com?plugins=typography"></script>
</head>
<body class="bg-gray-50 font-sans">
  <slot />
</body>
</html>
