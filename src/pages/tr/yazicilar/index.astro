---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';

const printers = (await getCollection('printers')).sort((a, b) =>
  `${a.data.brand} ${a.data.model}`.localeCompare(`${b.data.brand} ${b.data.model}`)
);

const classLabels: Record<string, string> = {
  mobile: 'Mobil',
  desktop: 'Masaüstü',
  industrial: 'Endüstriyel',
};
const connectionLabels: Record<string, string> = {
  bluetooth: 'Bluetooth',
  wifi: 'Wi-Fi',
  usb: 'USB',
  ethernet: 'Ethernet',
};
---
<BaseLayout lang="tr" title="Yazıcı Uyumluluk Veritabanı — Printzen" description="Mobil, masaüstü ve endüstriyel termal yazıcılar için marka, bağlantı tipi ve komut diline göre uyumluluk listesi." alternatePath="/printers/">
  <Nav wide lang="tr" alternatePath="/printers/" />

  <main class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Yazıcı Uyumluluk Veritabanı</h1>
    <p class="text-gray-500 mb-10">Termal ve termal transfer yazıcılar — sınıf, bağlantı tipi ve komut diline göre.</p>

    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4">Marka / Model</th>
            <th class="py-3 pr-4">Sınıf</th>
            <th class="py-3 pr-4">Bağlantı</th>
            <th class="py-3 pr-4">Komut Dili</th>
            <th class="py-3 pr-4">Baskı Türü</th>
            <th class="py-3">Mobile Print Service</th>
          </tr>
        </thead>
        <tbody>
          {printers.map((printer) => (
            <tr class="border-b border-gray-100">
              <td class="py-3 pr-4 font-medium text-gray-900">{printer.data.brand} {printer.data.model}</td>
              <td class="py-3 pr-4 text-gray-600">{classLabels[printer.data.class]}</td>
              <td class="py-3 pr-4 text-gray-600">{printer.data.connections.map((c) => connectionLabels[c]).join(', ')}</td>
              <td class="py-3 pr-4 text-gray-600">{printer.data.commandLanguage}</td>
              <td class="py-3 pr-4 text-gray-600">{printer.data.printType === 'thermal-transfer' ? 'Termal transfer' : 'Doğrudan termal'}</td>
              <td class="py-3">
                {printer.data.tested ? (
                  <span class="text-green-600 font-medium">✓ Destekleniyor</span>
                ) : (
                  <span class="text-gray-400">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>

  <Footer lang="tr" />
</BaseLayout>
