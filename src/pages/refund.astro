---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout lang="en" title="Refund Policy — Printzen">
  <Nav lang="en" />

  <main class="max-w-3xl mx-auto px-4 py-16">
    <div class="prose max-w-none">
      <h1 class="text-3xl font-bold mb-2">Refund Policy</h1>
      <p class="text-gray-400 text-sm mb-8">Last updated: July 2026</p>

      <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
        <p class="text-green-800 font-semibold text-lg">30-Day Money-Back Guarantee</p>
        <p class="text-green-700 mt-1">If you're not satisfied for any reason, contact us within 30 days of purchase for a full refund — no questions asked.</p>
      </div>

      <h2 class="text-xl font-bold mt-8 mb-3">Eligibility</h2>
      <p class="text-gray-600 mb-4">You are eligible for a full refund if your request is made within 30 days of the original purchase date. No questions asked.</p>

      <h2 class="text-xl font-bold mt-8 mb-3">Refunding Directly Through Google Play</h2>
      <p class="text-gray-600 mb-4">All purchases are made through Google Play. Within 48 hours of purchase, you can request a refund directly from Google Play with no need to contact us — see <a href="https://support.google.com/googleplay/answer/2479637" target="_blank" rel="noopener" class="text-blue-600 hover:underline">Google Play's refund help</a>.</p>

      <h2 class="text-xl font-bold mt-8 mb-3">How to Request a Refund From Us</h2>
      <p class="text-gray-600 mb-4">After 48 hours (and within 30 days of purchase), send an email to <a href="mailto:support@printzen.app" class="text-blue-600 hover:underline">support@printzen.app</a> with:</p>
      <ul class="list-disc list-inside text-gray-600 mb-4 space-y-1">
        <li>Your Google Play order number (starts with "GPA.")</li>
        <li>The email address used at purchase</li>
        <li>Reason for the refund request (optional, helps us improve)</li>
      </ul>
      <p class="text-gray-600 mb-4">We will process your refund within 5 business days through Google Play Console. The refund will be issued to your original Google Play payment method.</p>

      <h2 class="text-xl font-bold mt-8 mb-3">After a Refund</h2>
      <p class="text-gray-600 mb-4">Once Google Play processes the refund, your purchase entitlement is revoked on Google's side. The app checks your purchase status each time you open it, so Pro features are removed the next time you open the app.</p>

      <h2 class="text-xl font-bold mt-8 mb-3">Contact</h2>
      <p class="text-gray-600 mb-4">Questions? <a href="mailto:support@printzen.app" class="text-blue-600 hover:underline">support@printzen.app</a></p>
    </div>
  </main>

  <Footer lang="en" />
</BaseLayout>
