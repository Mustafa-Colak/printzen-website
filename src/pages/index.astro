---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const recentGuides = (await getCollection('guides'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---
<BaseLayout
  title="Printzen — Mobile Print Service for Android"
  description="Print from any Android app to any thermal printer. Bluetooth, Wi-Fi, USB support."
>
  <Nav wide>
    <a href="https://play.google.com/store/apps/details?id=com.mobileprint.service" target="_blank" rel="noopener" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
      <span class="en">Get on Play Store</span><span class="tr">Play Store'dan Al</span>
    </a>
  </Nav>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 py-20">
    <div class="grid md:grid-cols-5 gap-12 items-center">
      <div class="md:col-span-3">
        <div class="inline-block bg-blue-50 text-blue-700 text-sm font-medium px-4 py-1 rounded-full mb-6">
          <span class="en">Android Print Service</span><span class="tr">Android Yazdırma Servisi</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          <span class="en">Print from any Android app<br>to any thermal printer</span>
          <span class="tr">Her Android uygulamasından<br>her termal yazıcıya yazdır</span>
        </h1>
        <p class="text-xl text-gray-500 mb-10">
          <span class="en">Mobile Print Service connects your Android device to receipt and label printers via Bluetooth, Wi-Fi, or USB — through the system print dialog.</span>
          <span class="tr">Mobile Print Service, Android cihazınızı sistem yazdırma dialogu üzerinden fiş ve etiket yazıcılara Bluetooth, Wi-Fi veya USB ile bağlar.</span>
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://play.google.com/store/apps/details?id=com.mobileprint.service" target="_blank" rel="noopener"
             class="bg-blue-600 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-blue-700 transition inline-flex items-center gap-2 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3 20.5v-17c0-.83 1.01-1.3 1.66-.78l15 8.5a1 1 0 010 1.56l-15 8.5C4.01 21.8 3 21.33 3 20.5z"/></svg>
            <span class="en">Get on Google Play</span><span class="tr">Google Play'den İndir</span>
          </a>
          <a href="#pricing" class="bg-white text-blue-600 border border-blue-200 px-8 py-4 rounded-xl text-lg font-semibold hover:bg-blue-50 transition inline-block shadow">
            <span class="en">View Pricing →</span><span class="tr">Fiyatları Gör →</span>
          </a>
        </div>
        <p class="text-sm text-gray-400 mt-4">
          <span class="en">30-day free trial · No credit card required</span>
          <span class="tr">30 günlük ücretsiz deneme · Kredi kartı gerekmez</span>
        </p>
      </div>

      <div class="md:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-gray-900">
            <span class="en">Recent guides</span><span class="tr">Son rehberler</span>
          </h2>
          <a href="/guides" class="text-sm text-blue-600 hover:underline shrink-0">
            <span class="en">View all →</span><span class="tr">Tümünü gör →</span>
          </a>
        </div>
        <div class="divide-y divide-gray-100">
          {recentGuides.map((guide) => (
            <a href={`/guides/${guide.slug}`} class="flex items-center gap-3 py-3 group">
              <div class="text-blue-600 shrink-0">📄</div>
              <div>
                <p class="text-sm font-medium text-gray-900 group-hover:text-blue-600 transition">
                  <span class="en">{guide.data.title.en}</span><span class="tr">{guide.data.title.tr}</span>
                </p>
              </div>
            </a>
          ))}
        </div>
        <a href="/printers" class="block mt-4 pt-4 border-t border-gray-100 text-sm text-blue-600 hover:underline">
          <span class="en">Browse the printer compatibility database →</span>
          <span class="tr">Yazıcı uyumluluk veritabanına göz atın →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <div class="text-3xl mb-3">🖨️</div>
        <h3 class="font-bold text-lg mb-2">
          <span class="en">System Print Dialog</span>
          <span class="tr">Sistem Print Dialogu</span>
        </h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          <span class="en">Works with any Android app that supports printing — Chrome, Google Docs, your own app — no modification needed.</span>
          <span class="tr">Chrome, Google Docs ve kendi uygulamanız dahil yazdırmayı destekleyen her Android uygulamasıyla çalışır.</span>
        </p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <div class="text-3xl mb-3">📶</div>
        <h3 class="font-bold text-lg mb-2">
          <span class="en">Multiple Connections</span>
          <span class="tr">Çoklu Bağlantı</span>
        </h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          <span class="en">Bluetooth, Wi-Fi, and USB OTG. Supports Zebra, Honeywell, TSC, Seiko, Bixolon, Sewoo, Rongta, and any generic ESC/POS thermal printer.</span>
          <span class="tr">Bluetooth, Wi-Fi ve USB OTG. Zebra, Honeywell, TSC, Seiko, Bixolon, Sewoo, Rongta ve tüm genel ESC/POS termal yazıcıları destekler.</span>
        </p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="font-bold text-lg mb-2">
          <span class="en">HTTP API</span>
          <span class="tr">HTTP API</span>
        </h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          <span class="en">Send PDF, images, or raw ESC/POS data from any app on your local network via a simple REST API.</span>
          <span class="tr">Yerel ağınızdaki herhangi bir uygulamadan PDF, görsel veya ham ESC/POS verisi gönderin.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="max-w-4xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-4">
      <span class="en">Simple, one-time pricing</span>
      <span class="tr">Basit, tek seferlik ödeme</span>
    </h2>
    <p class="text-center text-gray-500 mb-12">
      <span class="en">Buy once on Google Play, use forever. No subscriptions.</span>
      <span class="tr">Google Play'den bir kez öde, sonsuza kadar kullan. Abonelik yok.</span>
    </p>

    <div class="grid md:grid-cols-2 gap-8 items-stretch">

      <!-- BT Plan -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-200 flex flex-col">
        <div class="flex items-center gap-3 mb-2">
          <div class="bg-blue-50 rounded-xl p-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5l8 6-8 6V5zM16 5v14"/></svg>
          </div>
          <h3 class="font-bold text-xl"><span class="en">BT Plan</span><span class="tr">BT Planı</span></h3>
        </div>
        <div class="text-5xl font-bold mb-1 mt-4">$9.90</div>
        <p class="text-gray-400 text-xs mb-6">
          <span class="en">one-time · Google Play</span><span class="tr">tek seferlik · Google Play</span>
        </p>
        <ul class="text-sm text-gray-600 space-y-3 mb-8 flex-1">
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> <span class="en">Bluetooth printing</span><span class="tr">Bluetooth yazdırma</span></li>
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> <span class="en">USB OTG printing</span><span class="tr">USB OTG yazdırma</span></li>
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> <span class="en">All printer brands</span><span class="tr">Tüm yazıcı markaları</span></li>
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> <span class="en">Free updates</span><span class="tr">Ücretsiz güncellemeler</span></li>
          <li class="flex items-center gap-2"><span class="text-red-400">✗</span> <span class="line-through en">Wi-Fi printing</span><span class="line-through tr">Wi-Fi yazdırma</span></li>
          <li class="flex items-center gap-2"><span class="text-red-400">✗</span> <span class="line-through en">HTTP API</span><span class="line-through tr">HTTP API</span></li>
        </ul>
        <a href="https://play.google.com/store/apps/details?id=com.mobileprint.service" target="_blank" rel="noopener" class="block text-center bg-gray-900 text-white py-3 rounded-xl font-medium hover:bg-gray-700 transition">
          <span class="en">Get on Play Store</span><span class="tr">Play Store'dan Al</span>
        </a>
      </div>

      <!-- Full Plan (Popular) -->
      <div class="bg-blue-600 rounded-2xl p-8 shadow-xl text-white relative flex flex-col">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-orange-400 text-white text-xs px-4 py-1.5 rounded-full font-bold whitespace-nowrap">
          <span class="en">RECOMMENDED</span><span class="tr">ÖNERİLEN</span>
        </div>
        <div class="flex items-center gap-3 mb-2">
          <div class="bg-white/20 rounded-xl p-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>
          </div>
          <h3 class="font-bold text-xl"><span class="en">Full Plan</span><span class="tr">Tam Plan</span></h3>
        </div>
        <div class="text-5xl font-bold mb-1 mt-4">$14.90</div>
        <p class="text-blue-200 text-xs mb-6">
          <span class="en">one-time · Google Play</span><span class="tr">tek seferlik · Google Play</span>
        </p>
        <ul class="text-sm text-blue-100 space-y-3 mb-8 flex-1">
          <li class="flex items-center gap-2"><span class="text-blue-200">✓</span> <span class="en">Bluetooth printing</span><span class="tr">Bluetooth yazdırma</span></li>
          <li class="flex items-center gap-2"><span class="text-blue-200">✓</span> <span class="en">USB OTG printing</span><span class="tr">USB OTG yazdırma</span></li>
          <li class="flex items-center gap-2"><span class="text-blue-200">✓</span> <span class="en">All printer brands</span><span class="tr">Tüm yazıcı markaları</span></li>
          <li class="flex items-center gap-2"><span class="text-blue-200">✓</span> <span class="en">Free updates</span><span class="tr">Ücretsiz güncellemeler</span></li>
          <li class="flex items-center gap-2"><span class="text-blue-200">✓</span> <span class="en">Wi-Fi printing</span><span class="tr">Wi-Fi yazdırma</span></li>
          <li class="flex items-center gap-2"><span class="text-blue-200">✓</span> <span class="en">HTTP API access</span><span class="tr">HTTP API erişimi</span></li>
        </ul>
        <a href="https://play.google.com/store/apps/details?id=com.mobileprint.service" target="_blank" rel="noopener" class="block text-center bg-white text-blue-600 py-3 rounded-xl font-medium hover:bg-blue-50 transition">
          <span class="en">Get on Play Store</span><span class="tr">Play Store'dan Al</span>
        </a>
      </div>

    </div>

    <p class="text-center text-gray-400 text-sm mt-8">
      <span class="en">Both plans include a 30-day free trial. Cancel anytime before trial ends.</span>
      <span class="tr">Her iki plan da 30 günlük ücretsiz deneme içerir. Deneme bitmeden istediğiniz zaman iptal edin.</span>
    </p>
  </section>

  <Footer />
</BaseLayout>
