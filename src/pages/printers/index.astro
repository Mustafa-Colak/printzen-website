---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const printers = (await getCollection('printers')).sort((a, b) =>
  `${a.data.brand} ${a.data.model}`.localeCompare(`${b.data.brand} ${b.data.model}`)
);

const classLabels: Record<string, string> = {
  mobile: 'Mobile',
  desktop: 'Desktop',
  industrial: 'Industrial',
};
const connectionLabels: Record<string, string> = {
  bluetooth: 'Bluetooth',
  wifi: 'Wi-Fi',
  usb: 'USB',
  ethernet: 'Ethernet',
};
---
<BaseLayout lang="en" title="Printer Compatibility Database — Printzen" description="Compatibility list for mobile, desktop, and industrial thermal printers by brand, connection type, and command language." alternatePath="/tr/yazicilar/">
  <Nav wide lang="en" alternatePath="/tr/yazicilar/" />

  <main class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Printer Compatibility Database</h1>
    <p class="text-gray-500 mb-10">Thermal and thermal transfer printers — by class, connection type, and command language.</p>

    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4">Brand / Model</th>
            <th class="py-3 pr-4">Class</th>
            <th class="py-3 pr-4">Connection</th>
            <th class="py-3 pr-4">Command Language</th>
            <th class="py-3 pr-4">Print Type</th>
            <th class="py-3">Mobile Print Service</th>
          </tr>
        </thead>
        <tbody>
          {printers.map((printer) => (
            <tr class="border-b border-gray-100">
              <td class="py-3 pr-4 font-medium text-gray-900">{printer.data.brand} {printer.data.model}</td>
              <td class="py-3 pr-4 text-gray-600">{classLabels[printer.data.class]}</td>
              <td class="py-3 pr-4 text-gray-600">{printer.data.connections.map((c) => connectionLabels[c]).join(', ')}</td>
              <td class="py-3 pr-4 text-gray-600">{printer.data.commandLanguage}</td>
              <td class="py-3 pr-4 text-gray-600">{printer.data.printType === 'thermal-transfer' ? 'Thermal transfer' : 'Direct thermal'}</td>
              <td class="py-3">
                {printer.data.tested ? (
                  <span class="text-green-600 font-medium">✓ Supported</span>
                ) : (
                  <span class="text-gray-400">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>

  <Footer lang="en" />
</BaseLayout>
