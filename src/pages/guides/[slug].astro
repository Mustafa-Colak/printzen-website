---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props;
const { Content } = await guide.render();

const classLabels: Record<string, { en: string; tr: string }> = {
  mobile: { en: 'Mobile', tr: 'Mobil' },
  desktop: { en: 'Desktop', tr: 'Masaüstü' },
  industrial: { en: 'Industrial', tr: 'Endüstriyel' },
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.data.title.tr,
  description: guide.data.description.tr,
  datePublished: guide.data.publishDate.toISOString(),
  author: { '@type': 'Organization', name: 'Printzen' },
};
---
<BaseLayout title={`${guide.data.title.tr} — Printzen`} description={guide.data.description.tr}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Nav />

  <main class="max-w-3xl mx-auto px-4 py-16">
    <a href="/guides" class="text-sm text-blue-600 hover:underline">
      <span class="en">← All guides</span><span class="tr">← Tüm rehberler</span>
    </a>
    <span class="inline-block text-xs font-medium text-blue-600 bg-blue-50 rounded-full px-3 py-1 mt-4 mb-3">
      <span class="en">{classLabels[guide.data.printerClass].en}</span><span class="tr">{classLabels[guide.data.printerClass].tr}</span>
      {guide.data.brand ? ` · ${guide.data.brand}` : ''}
    </span>
    <h1 class="text-3xl font-bold mb-6">
      <span class="en">{guide.data.title.en}</span><span class="tr">{guide.data.title.tr}</span>
    </h1>
    <article class="prose max-w-none prose-headings:font-bold prose-a:text-blue-600">
      <Content />
    </article>
  </main>

  <Footer />
</BaseLayout>
