---
import { getAlternatePath, type Locale } from '../utils/i18n';

interface Props {
  lang: Locale;
  wide?: boolean;
}
const { lang, wide = false } = Astro.props;
const prefix = lang === 'tr' ? '/tr' : '';
const alternatePath = getAlternatePath(Astro.url.pathname, lang);
---
<nav class="bg-white shadow-sm sticky top-0 z-10">
  <div class={`${wide ? 'max-w-5xl' : 'max-w-3xl'} mx-auto px-4 py-4 flex items-center justify-between gap-4`}>
    <a href={lang === 'tr' ? '/tr/' : '/'} class="text-2xl font-bold text-blue-600 shrink-0">Printzen Apps</a>
    <div class="hidden sm:flex items-center gap-5 text-sm text-gray-600">
      <a href={`${prefix}/guides`} class="hover:text-blue-600 transition">{lang === 'tr' ? 'Rehberler' : 'Guides'}</a>
      <a href={`${prefix}/printers`} class="hover:text-blue-600 transition">{lang === 'tr' ? 'Yazıcılar' : 'Printers'}</a>
    </div>
    <div class="flex items-center gap-4">
      <a href={alternatePath} class="text-sm border border-gray-300 rounded px-3 py-1 hover:bg-gray-100 transition">
        {lang === 'tr' ? 'EN' : 'TR'}
      </a>
      <slot />
    </div>
  </div>
</nav>
